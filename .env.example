# Shopify App Bridge
# Your Client ID from Partner Dashboard > Apps > [Your App] > Client credentials
VITE_SHOPIFY_API_KEY=your_api_key_here

# Dev store (used for local UI development outside Shopify admin)
VITE_DEV_STORE_URL=your-store.myshopify.com

# Your app's backend API base URL
VITE_API_URL=http://localhost:8000

# App code identifier (used by Apphub token exchange + plan endpoints)
VITE_APP_CODE=your-app-code

# App handle as registered in the Shopify Partner Dashboard. Used to build the
# returnUrl after a billing confirmation (admin.shopify.com/store/<slug>/apps/<handle>/...).
VITE_APP_HANDLE=your-app-handle

# Apphub API base URL (token exchange, billing)
VITE_APPHUB_URL=https://apphub.example.com

# Run the app against MSW handlers in src/mocks/ — no backend required.
# Set to "true" to enable. Run `npx msw init public/` once before first use.
VITE_USE_MOCK=false

# PostHog analytics (optional). When VITE_POSTHOG_KEY is empty the module
# is inert — initPostHog() / identifyShop() / capture() become no-ops.
# Activates only in production builds (PROD === true).
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Logger overrides (optional). The baseline lives in src/config/logging.ts;
# these env vars let a single build be retuned at deploy time without code
# changes. Sinks is a comma-separated list of "console" and/or "posthog".
# VITE_LOG_LEVEL=info
# VITE_LOG_SINKS=console,posthog

# Support contact (optional). Defaults are set in src/config/env.ts.
# VITE_SUPPORT_EMAIL=steve@upatra.com
# VITE_SUPPORT_HINT=Please include your Shopify store URL...

# Internationalization (optional). When "false", the app pins to English
# regardless of the Shopify admin locale. Defaults to true.
# VITE_ENABLE_I18N=true
